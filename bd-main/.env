# База данных PostgreSQL (обязательно!)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Схема базы данных (из миграций)
MAIN_DB_SCHEMA=t_p79040548_accounting_automatio

# Poehali.dev S3 (для хранения файлов)
AWS_ACCESS_KEY_ID=your_poehali_key
AWS_SECRET_ACCESS_KEY=your_poehali_secret

# API ключи AI (опционально, можно задать в интерфейсе)
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
PROXYAPI_KEY=

# Фронтенд — пустая строка = относительные запросы /api/*
VITE_API_URL=
VITE_CDN_URL=https://cdn.poehali.dev
